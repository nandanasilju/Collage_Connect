datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                String           @id @default(cuid())
  name              String
  email             String           @unique
  password          String
  profileImage      String?
  preferredBranch   String?
  preferredLocation String?
  budget            Float?
  role              String           @default("USER") // USER, ADMIN
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  savedColleges     SavedCollege[]
  reviews           Review[]
  recentlyViewed    RecentlyViewed[]
  reviewLikes       ReviewLike[]
}

model College {
  id                  String           @id @default(cuid())
  name                String
  location            String
  district            String
  state               String
  type                String           // Government, Private
  autonomous          Boolean          @default(false)
  description         String
  fees                Float
  rating              Float            @default(0.0)
  placementPercentage Float            @default(0.0)
  highestPackage      Float            @default(0.0)
  averagePackage      Float            @default(0.0)
  hostel              Boolean          @default(false)
  transport           Boolean          @default(false)
  website             String
  image               String
  aiScore             Float            @default(0.0)
  latitude            Float
  longitude           Float
  nearbyBusStand      String?
  nearbyRailway       String?
  nearbyAirport       String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  images              CollegeImage[]
  courses             Course[]
  facilities          Facility[]
  savedByUsers        SavedCollege[]
  reviews             Review[]
  recentlyViewedByUsers RecentlyViewed[]
}

model CollegeImage {
  id        String   @id @default(cuid())
  url       String
  collegeId String
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
}

model Course {
  id        String   @id @default(cuid())
  name      String
  duration  String   @default("4 Years")
  intake    Int      @default(60)
  collegeId String
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
}

model Facility {
  id        String   @id @default(cuid())
  name      String
  collegeId String
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
}

model SavedCollege {
  id        String   @id @default(cuid())
  userId    String
  collegeId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@unique([userId, collegeId])
}

model Review {
  id        String       @id @default(cuid())
  rating    Int
  comment   String
  approved  Boolean      @default(true)
  userId    String
  collegeId String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  college   College      @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  likes     ReviewLike[]
}

model ReviewLike {
  userId   String
  reviewId String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@id([userId, reviewId])
}

model RecentlyViewed {
  id        String   @id @default(cuid())
  userId    String
  collegeId String
  viewedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@unique([userId, collegeId])
}
